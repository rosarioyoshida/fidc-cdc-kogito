flowchart LR
    subgraph FE["Frontends / Canais de Uso"]
        U1["Frontend de Negócio<br/>(portal, app, sistema corporativo)"]
        U2["Management Console"]
        U3["Task Console"]
    end

    subgraph BE["Backend de Execução"]
        KPS["Serviço Kogito de Processo<br/>(BPMN, regras, APIs)"]
    end

    subgraph RDB["Persistência Transacional"]
        MYSQL["MySQL<br/>(estado transacional do runtime)"]
    end

    subgraph EVT["Mensageria / Eventos"]
        KAFKA["Kafka"]
    end

    subgraph SUP["Serviços de Apoio do Kogito"]
        DI["Kogito Data Index"]
        JOBS["Kogito Jobs Service"]
    end

    subgraph IDX["Persistência Indexada / Consulta"]
        MONGO["MongoDB<br/>(processos, tarefas e jobs indexados)"]
    end

    U1 -->|"inicia processos / consulta status / envia comandos"| KPS

    KPS -->|"persiste estado da instância,<br/>variáveis e dados de execução"| MYSQL

    KPS -->|"publica eventos de processo,<br/>tarefas e execução"| KAFKA
    JOBS -->|"publica eventos de jobs"| KAFKA
    KAFKA -->|"entrega eventos"| DI

    DI -->|"persiste dados indexados para consulta"| MONGO

    KPS -->|"agenda timers / jobs"| JOBS
    JOBS -->|"notifica vencimento / callback temporizado"| KPS

    U2 -->|"consulta visão operacional"| DI
    U3 -->|"consulta tarefas humanas"| DI

    U2 -->|"comandos operacionais sobre instâncias"| KPS
    U3 -->|"completa / executa tarefas humanas"| KPS